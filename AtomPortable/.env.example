# =============================================================================
# AtoM Portable + Asistente IA — Configuración
# =============================================================================
# INSTRUCCIONES:
#   1. Copie este fichero como .env  (copy .env.example .env)
#   2. Sustituya todos los valores que ponen CAMBIAR_ESTO por sus contraseñas
#   3. Guarde el fichero y ejecute 1_preparar_atom.bat
#
# IMPORTANTE: El fichero .env nunca se sube a GitHub (está en .gitignore).
#             Guárdelo en un lugar seguro.
# =============================================================================

# --- Base de datos (MySQL / Percona) -----------------------------------------
# Contraseña del usuario root de MySQL (administración interna)
MYSQL_ROOT_PASSWORD=CAMBIAR_ESTO

# Contraseña del usuario "atom" de la base de datos
ATOM_MYSQL_PASSWORD=CAMBIAR_ESTO

# --- AtoM — cuenta de administrador ------------------------------------------
# Correo electrónico del administrador de AtoM
ATOM_ADMIN_EMAIL=admin@atom.local

# Contraseña del administrador de AtoM (para entrar en http://localhost:8080)
ATOM_ADMIN_PASSWORD=Archivos#2024


# --- Puertos (opcional) -------------------------------------------------------
# Solo modifique si esos puertos están ocupados en su equipo
# ATOM_PORT=8080
# ASISTENTE_PORT=8081

# --- Conexión interna (no modificar) -----------------------------------------
ATOM_DEVELOPMENT_MODE=off
ATOM_ELASTICSEARCH_HOST=elasticsearch
ATOM_MEMCACHED_HOST=memcached
ATOM_GEARMAND_HOST=gearmand
ATOM_MYSQL_DSN=mysql:host=percona;port=3306;dbname=atom;charset=utf8mb4
ATOM_MYSQL_USERNAME=atom
